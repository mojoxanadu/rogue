<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Proxies.sx Peer"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <TextView android:id="@+id/state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:paddingBottom="12dp" />

        <!-- Status row: verified state on the left, traffic-light dot
             and throughput readout on the right. Horizontal so the
             signal sits to the immediate right of the status text. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">

            <TextView android:id="@+id/verified"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView android:id="@+id/signalDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:text="●"
                android:textColor="#888888"
                android:paddingEnd="6dp" />

            <TextView android:id="@+id/throughput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <TextView android:id="@+id/probeCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:paddingBottom="12dp" />

        <TextView android:id="@+id/deviceId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingBottom="16dp" />

        <!-- Earnings summary + payout button. Polled every 60s by
             PeerService. Button is disabled until canRequestPayout flips
             true (proxies.sx threshold is $5 USDC). -->
        <TextView android:id="@+id/earnings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:paddingBottom="8dp"
            android:text="Earnings: (fetching…)" />

        <Button android:id="@+id/payout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:text="Request payout"
            android:layout_marginBottom="16dp" />

        <!-- Shown only while not yet verified. GONE once verified so the
             screen tightens up. -->
        <LinearLayout android:id="@+id/tips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#22FFAA00"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tips to help verification"
                android:textStyle="bold"
                android:textSize="14sp"
                android:paddingBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:lineSpacingExtra="3dp"
                android:text="• Pause BitTorrent / heavy upload apps (Flud, etc.) — contention makes the 500 KB/s probe fail.\n• Move to a window or step outside until verified (~15 min of decent signal). 1 bar of cellular usually can't sustain 4 Mbps.\n• Need 3 consecutive 5-min probes to pass — drops reset progress.\n• Wi-Fi will probably verify faster but drops you to the residential ($2.24/GB) or datacenter ($0.56/GB) tier instead of mobile ($4.48/GB).\n• Once verified, brief signal dips are fine — the bar is for promotion, not maintenance." />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Latest log line:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingTop="12dp" />

        <!-- Fixed-height log line: caps at 4 lines + ellipsis so a long
             relay URL or stack trace can't shift the buttons below it. -->
        <TextView android:id="@+id/lastLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:maxLines="4"
            android:ellipsize="end"
            android:paddingBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="The peer keeps running in the background even if you close this screen or lock the phone. The ongoing notification is the only thing required."
            android:textSize="12sp"
            android:paddingBottom="20dp" />

        <Button android:id="@+id/stop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stop service" />
    </LinearLayout>
</ScrollView>
